rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // נתוני משתמשים - רק המשתמש עצמו
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // חסום הכל אחר
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
